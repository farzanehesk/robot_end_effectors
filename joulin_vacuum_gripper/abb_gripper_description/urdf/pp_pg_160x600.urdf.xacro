<?xml version="1.0"?>
<!--
  ============================================================
  Package:     abb_gripper_description
  File:        pp_pg_160x600.urdf.xacro
  Description: URDF/xacro for Joulin PP-PG-160x600-P20-2STX4
               pneumatic vacuum gripper on ABB IRB6700 175/3.05
  Author:      Farzaneh Eskandari
  Email:       farzane.eskandarii@gmail.com
  Date:        2026-06-05
  ============================================================

  Physical dimensions (from datasheet + STL bounding box):
    Length: 600mm (X axis in mesh)
    Width:  160mm (Z axis in mesh)
    Height:  87mm (Y axis in mesh, origin at TOP = flange face)
    Weight:  4.6 kg

  STL coordinate system:
    X: -300 to +300  (600mm length, centered)
    Y:    0 to  +87  (87mm height, Y=0 is mounting face)
    Z:  -80 to  +80  (160mm width, centered)
    Top face normals point +Y

  Visual rotation: rpy="${pi/2} ${pi} ${-pi/2}"
    Maps STL to correct orientation with mounting face at tool parent

  USAGE:
    <xacro:include filename="$(find abb_gripper_description)/urdf/pp_pg_160x600.urdf.xacro"/>
    <xacro:pp_pg_160x600 parent="rob1_swa_160_tool_mount" prefix="rob1_"/>

  TO REMOVE: comment out those two lines.

  TCP frame: rob1_gripper_tcp — 87mm forward from parent frame
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="pp_pg_160x600" params="parent prefix">

    <link name="${prefix}gripper_base_link">
      <visual>
        <origin xyz="0 0 0.087" rpy="${pi/2} ${pi} ${-pi/2}"/>
        <geometry>
          <mesh filename="package://abb_gripper_description/meshes/pp_pg_160x600.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="gripper_grey">
          <color rgba="0.6 0.6 0.65 1.0"/>
        </material>
      </visual>

      <collision>
        <!-- Same rotation as visual so box aligns with mesh -->
        <origin xyz="0 0 0.087" rpy="${pi/2} ${pi} ${-pi/2}"/>
        <geometry>
          <!-- In STL frame: X=600mm, Y=87mm depth, Z=160mm width -->
          <box size="0.600 0.087 0.160"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="4.6"/>
        <origin xyz="0 0 0.0435" rpy="0 0 0"/>
        <inertia
          ixx="0.03481" ixy="0.0" ixz="0.0"
          iyy="0.13880" iyz="0.0"
          izz="0.14827"/>
      </inertial>
    </link>

    <joint name="${prefix}tool0_to_gripper" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}gripper_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}gripper_tcp"/>
    <joint name="${prefix}gripper_base_to_tcp" type="fixed">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}gripper_tcp"/>
      <origin xyz="0 0 0.087" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
