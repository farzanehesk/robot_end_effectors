<?xml version="1.0"?>
<!--
  ============================================================
  Package:     sws_160_description
  Description: URDF/xacro for Schunk SWS-160 automatic tool
               changer (SWK-160 robot side + SWA-160 tool side)
  Robot:       ABB IRB6700 175/3.05 on IRBT6004 7m rail
  Author:      Farzaneh Eskandari
  Email:       farzane.eskandarii@gmail.com
  Date:        2026-06-05
  ============================================================

  Rotation rpy="${pi/2} ${pi} ${-pi/2}" maps STL Y → URDF -Z

  SWK-160: Y=-30 (flange face) to Y=+70.6 (interface) = 100.6mm
    After rotation: flange face at URDF Z=+30, interface at URDF Z=-70.6
    Visual offset = total_height - abs(Y_min) = 100.6 - 30 = 70.6mm
    → xyz="0 0 0.0706" places flange face flush at link origin (Z=0)

  SWA-160: Y=-37.5 (tool mount) to Y=0 (interface) = 37.6mm
    After rotation: interface at URDF Z=0, tool mount at URDF Z=+37.5
    Visual offset = abs(Y_min) = 37.5mm
    → xyz="0 0 0.0375" places interface face flush at link origin (Z=0)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="swk_160_robot_side" params="parent prefix">
    <link name="${prefix}swk_160_link">
      <visual>
        <origin xyz="0 0 0.0706" rpy="${pi/2} ${pi} ${-pi/2}"/>
        <geometry>
          <mesh filename="package://sws_160_description/meshes/swk_160_robot_side_bin.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="schunk_grey">
          <color rgba="0.4 0.4 0.4 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.0503" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.088" length="0.1006"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.0"/>
        <origin xyz="0 0 0.0503" rpy="0 0 0"/>
        <inertia ixx="0.004" ixy="0.0" ixz="0.0"
                 iyy="0.004" iyz="0.0" izz="0.007"/>
      </inertial>
    </link>

    <joint name="${prefix}tool0_to_swk_160" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}swk_160_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}swk_160_interface"/>
    <joint name="${prefix}swk_160_to_interface" type="fixed">
      <parent link="${prefix}swk_160_link"/>
      <child link="${prefix}swk_160_interface"/>
      <origin xyz="0 0 0.1006" rpy="0 0 0"/>
    </joint>
  </xacro:macro>


  <xacro:macro name="swa_160_tool_side" params="parent prefix">
    <link name="${prefix}swa_160_link">
      <visual>
        <origin xyz="0 0 0.0375" rpy="${pi/2} ${pi} ${-pi/2}"/>
        <geometry>
          <mesh filename="package://sws_160_description/meshes/swa_160_tool_side_bin.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="schunk_grey">
          <color rgba="0.4 0.4 0.4 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.0188" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.088" length="0.0376"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0.0188" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0" izz="0.003"/>
      </inertial>
    </link>

    <joint name="${prefix}swk_interface_to_swa_160" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}swa_160_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}swa_160_tool_mount"/>
    <joint name="${prefix}swa_160_to_tool_mount" type="fixed">
      <parent link="${prefix}swa_160_link"/>
      <child link="${prefix}swa_160_tool_mount"/>
      <origin xyz="0 0 0.0376" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

</robot>